                  "typeValidation": "loose",
                  "version": 2
                },
                "conditions": [
                  {
                    "leftValue": "={{ $json.pathType }}",
                    "rightValue": "CTE Monthly",
                    "operator": {
                      "type": "string",
                      "operation": "equals"
                    },
                    "id": "988ef4b2-ab9a-43f0-91f5-6155afc3786d"
                  }
                ],
                "combinator": "and"
              },
              "renameOutput": true,
