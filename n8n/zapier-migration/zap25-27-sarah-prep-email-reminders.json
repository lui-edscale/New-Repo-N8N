{
  "name": "Zap #25+27: Sarah Prep Email Reminders (Implementation + CTE Monthly)",
  "nodes": [
    {
      "parameters": {
        "jsCode": "// Iterate over every queried page with EXPLICIT pairedItem so downstream\n// nodes (Gmail -> Notion update) can reliably trace each email back to its\n// own source page, even when multiple pages flow through in one batch.\n//\n// Note: input comes from Notion getAll node, which simplifies properties as\n// `property_<snake_case>` (different from Notion Trigger's flat output).\nconst items = $input.all();\nconst results = [];\n\nfor (let i = 0; i < items.length; i++) {\n  const trigger = items[i].json;\n  const emailList = trigger.property_mtg_attendees || '';\n\n  // Filter out edscalellc.com domain\n  const emails = emailList.split(/[,;\\s]+/).map(e => e.trim()).filter(e => e && !e.toLowerCase().includes('edscalellc.com'));\n\n  const title = trigger.property_task_name || '';\n\n  // Format date and time from property_due.start\n  const dueIso = trigger.property_due && trigger.property_due.start;\n  let meetingDate = '';\n  let meetingTime = '';\n  if (dueIso) {\n    const dt = DateTime.fromISO(dueIso, { zone: 'America/New_York' });\n    meetingDate = dt.toFormat('LLLL d, yyyy');\n    meetingTime = dt.toFormat('h:mm a ZZZZ');\n  }\n\n  const titleLower = title.toLowerCase();\n  const pathType = titleLower.startsWith('implementation session') ? 'Implementation Session'\n    : titleLower.startsWith('cte monthly') ? 'CTE Monthly'\n    : 'Other';\n\n  results.push({\n    json: {\n      toEmailsStr: emails.join(','),\n      meetingDate,\n      meetingTime,\n      title,\n      pageId: trigger.id,\n      pathType\n    },\n    pairedItem: { item: i }\n  });\n}\n\nreturn results;"
      },
      "id": "extract-data",
      "name": "Extract Email Recipients",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [592, 400]
    },
    {
